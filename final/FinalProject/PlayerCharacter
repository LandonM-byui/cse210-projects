public class PlayerCharacter : Character
{
    private int _DeathSuccess = 0;
    private int _DeathFail = 0;
    public PlayerCharacter(string name, int hp, int curHP = -1, int init = -10) : base (name, hp, curHP, init)
    {}


    public override void takeDamage(int amt)
    {
        if (_curHP - amt < 0)
        {
            _curHP = 0;
        }
        else
        {
            _curHP -= amt;
        }
    }

    public void DeathSave(int num)
    {
        if (num > 10)
        {
            _DeathSuccess += 1;
        }
        else if ( 10 >= num && num > 0)
        {
            _DeathFail += 1;
        }
        else
        {
            _DeathFail = 0;
            _DeathSuccess = 0;
        }
    }
}